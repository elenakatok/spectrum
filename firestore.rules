rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /game_instances/{instanceId}/participants/{participantId} {
      // Students can read their own record.
      allow read: if request.auth != null && request.auth.uid == participantId;

      // Students can update their own display_name and any prep answer field.
      // Uses a blocklist rather than an allowlist so the question editor can
      // introduce new field names (e.g. prep_abc123) without a rules redeploy.
      // Protected fields (role, scores, group assignment, timestamps) may not
      // be touched by a direct client write; create and delete remain denied.
      allow update: if request.auth != null
        && request.auth.uid == participantId
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['role', 'group_id', 'raw_score', 'normalized_score',
                      'knowledge_check_score', 'knowledge_check_attempts',
                      'prep_status', 'prep_completed_at', 'debrief_initial_offer',
                      'finalized_at', 'attendance_confirmed_at', 'confirmed_ready_at',
                      'is_lead', 'participant_id', 'game_instance_id', 'participant_late',
                      // Slice 0 team model — server-stamped, never client-writable.
                      // A student may READ their own team fields (own-doc read above);
                      // they may not forge them (a forged password would be a forged trade).
                      'team_number', 'team_password', 'team_synergy',
                      'team_endowment_regions', 'team_license_ids', 'team_cash',
                      'team_license_value', 'team_portfolio_value']);
    }

    // role_counts is an internal balancing counter — backend only.
    match /game_instances/{instanceId}/role_counts/{doc} {
      allow read, write: if false;
    }

    // Game config (PDF URLs, etc.) is backend-only.
    // Clients get only their role's private URL via the getInfoUrls Cloud Function,
    // which never exposes the other role's URL.
    match /game_instances/{instanceId}/config/{doc} {
      allow read, write: if false;
    }

    // Groups are written by the Cloud Function; any authenticated participant
    // can read them. Group docs carry PUBLIC team identity + license holdings only
    // (endowments are public, v3 §4). Cash, password, and synergy are NOT here.
    match /game_instances/{instanceId}/groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-team TRUTH (Slice 0): password + private synergy schedules + cash ledger seed.
    // Server-only — a leak collapses the game (v3 §3.6, §2.2). Rules do NOT cascade into
    // subcollections, so the group read rule above does not expose this; deny explicitly.
    match /game_instances/{instanceId}/groups/{groupId}/truth/{doc} {
      allow read, write: if false;
    }

    // License ownership board (Slice 0 endowments; Slice 1 ledger mutates it) — PUBLIC
    // (v3 §7.1: who holds which licenses is public; prices/cash never are). Server-written.
    match /game_instances/{instanceId}/licenses/{licenseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Market lifecycle + clock (status / opened_at / closes_at) — PUBLIC read, server-written.
    match /game_instances/{instanceId}/market/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Transaction ledger (Slice 1) — append-only, carries PRICES → server-only. The
    // History tab (Slice 3) serves a team its OWN transactions via a callable; direct
    // client reads are denied so no team can see another's prices (v3 §7.1).
    match /game_instances/{instanceId}/transactions/{txId} {
      allow read, write: if false;
    }

    // Auctions (Slice 1 settle primitive; Slice 2 lifecycle). The doc carries the PRIVATE
    // reserve, so it is server-only; the public live-auction feed (region/quantity, no
    // reserve, no price) is served separately in Slice 2. Bids are rules-denied until close.
    match /game_instances/{instanceId}/auctions/{auctionId} {
      allow read, write: if false;
    }
    match /game_instances/{instanceId}/auctions/{auctionId}/bids/{bidId} {
      allow read, write: if false;
    }

    // Slices 2–5 add per-team price data and the RTDB public feeds — all server-only.

    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
